<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Full-screen camera -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frozen capture frame (Persona-style screenshot) -->
    <ImageView
        android:id="@+id/capturedFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Camera flash effect -->
    <View
        android:id="@+id/flashOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/white"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings gear (top-right) -->
    <TextView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="12dp"
        android:gravity="center"
        android:text="⚙"
        android:textSize="22sp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animated scan overlay -->
    <com.parksence.ui.ScanOverlayView
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Result screen (replaces camera view) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/resultCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0D0D12"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="80dp">

            <!-- Verdict icon -->
            <TextView
                android:id="@+id/resultIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="64sp" />

            <!-- Title -->
            <TextView
                android:id="@+id/resultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@android:color/white" />

            <!-- Message -->
            <TextView
                android:id="@+id/resultMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:textSize="15sp"
                android:textColor="#AAFFFFFF"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

            <!-- Notes -->
            <TextView
                android:id="@+id/resultNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:background="@drawable/bg_notes_card"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:lineSpacingMultiplier="1.5"
                android:visibility="gone" />

            <!-- Signs header -->
            <TextView
                android:id="@+id/signsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"
                android:text="What I see on the pole"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#88FFFFFF"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:visibility="gone" />

            <!-- Signs list -->
            <LinearLayout
                android:id="@+id/signsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Scan again button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanAgain"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Scan again"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="28dp"
                app:backgroundTint="#1A1A2E"
                app:strokeColor="#334CAF50"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
